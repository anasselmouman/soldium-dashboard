# ─── Admin dashboard authentication ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_strong_password
# Secret for signing session cookies (use a long random string in production)
SECRET_KEY=change_this_to_a_long_random_secret
# Session cookie lifetime (seconds). Default: 30 days without remember-me, 90 with it.
# SESSION_MAX_AGE_SECONDS=2592000
# REMEMBER_ME_MAX_AGE_SECONDS=7776000
# Highly sensitive token for DELETE /api/system/reset-test-data
# RESET_TEST_DATA_TOKEN=change_me_to_a_long_random_string

# ─── SMM provider API (same 4-key setup as soldium-bot) ───
SMM_KEY_INSTAGRAM=your_instagram_smm_api_key_here
SMM_KEY_FACEBOOK=your_facebook_smm_api_key_here
SMM_KEY_TIKTOK=your_tiktok_smm_api_key_here
SMM_KEY_DEFAULT=your_default_smm_api_key_here
API_URL=https://gozibra.com/api/v2

# ─── Telegram bot (notifications) ───
# BOT_TOKEN=your_telegram_bot_token_here

# ─── Shared SQLite database ───
# SOLDIUM_DB_PATH=C:\path\to\soldium-bot\users.db
# SOLDIUM_DB_TIMEOUT=30.0
